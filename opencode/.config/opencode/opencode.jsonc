{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "/Users/kaisermann/.spoke-knowledge/instructions/main.md"
  ],
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "permission": {
    "external_directory": {
      "~/.spoke-knowledge": "allow",
      "~/.spoke-knowledge/**": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "svelte": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@sveltejs/mcp"
      ],
      "enabled": false
    }
  },
  "agent": {
    "general": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "explore": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "compaction": {
      "model": "github-copilot/claude-sonnet-4.6"
    }
  }
}
