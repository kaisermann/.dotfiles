#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")" && pwd)"

# ── Helpers ─────────────────────────────────────────────────────────
info()  { printf "\033[1;34m[info]\033[0m %s\n" "$1"; }
ok()    { printf "\033[1;32m[ ok ]\033[0m %s\n" "$1"; }
warn()  { printf "\033[1;33m[warn]\033[0m %s\n" "$1"; }
err()   { printf "\033[1;31m[err ]\033[0m %s\n" "$1"; }
skip()  { printf "\033[0;90m[skip]\033[0m %s\n" "$1"; }

# ── Usage ───────────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: ./install [options]

Bootstrap or update the dotfiles environment.
With no flags, runs all tasks. Use flags to run individual tasks.

Options:
  --brew      Install Homebrew and run Brewfile
  --volta     Install Volta and Node.js
  --stow      Stow all symlink packages
  --sheldon   Lock Sheldon plugins
  --macos     Apply macOS system defaults
  --shell     Set default shell to zsh
  --all       Run all tasks (default when no flags given)
  -h, --help  Show this help message
EOF
}

# ── Parse flags ─────────────────────────────────────────────────────
tasks=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --brew)    tasks+=(brew) ;;
    --volta)   tasks+=(volta) ;;
    --stow)    tasks+=(stow) ;;
    --sheldon) tasks+=(sheldon) ;;
    --macos)   tasks+=(macos) ;;
    --shell)   tasks+=(shell) ;;
    --all)     tasks=(brew volta stow sheldon macos shell) ;;
    -h|--help) usage; exit 0 ;;
    *)         err "Unknown option: $1"; usage; exit 1 ;;
  esac
  shift
done

# Default: run all tasks if no flags given
if [[ ${#tasks[@]} -eq 0 ]]; then
  tasks=(brew volta stow sheldon macos shell)
fi

should_run() { [[ " ${tasks[*]} " == *" $1 "* ]]; }

# ── Homebrew ────────────────────────────────────────────────────────
if should_run brew; then
  if ! command -v brew &>/dev/null; then
    info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  else
    skip "Homebrew already installed"
  fi

  info "Installing packages from Brewfile..."
  brew bundle install --file="$DOTFILES/Brewfile"
  ok "Homebrew + Brewfile"
fi

# ── Volta + Node ────────────────────────────────────────────────────
if should_run volta; then
  if ! command -v volta &>/dev/null; then
    info "Installing Volta..."
    curl https://get.volta.sh | bash -s -- --skip-setup
  else
    skip "Volta already installed"
  fi

  if ! volta list node 2>/dev/null | grep -q "node@"; then
    info "Installing Node via Volta..."
    volta install node
  else
    skip "Node already installed via Volta"
  fi

  if ! volta list all 2>/dev/null | grep -q "package chrome-devtools-cli@"; then
    info "Installing chrome-devtools-cli via Volta..."
    volta install chrome-devtools-cli
  else
    skip "chrome-devtools-cli already installed via Volta"
  fi

  ok "Volta + Node"
fi

# ── Stow packages ──────────────────────────────────────────────────
if should_run stow; then
  packages=(zsh sheldon starship git vim misc opencode)

  for pkg in "${packages[@]}"; do
    # Check if already correctly stowed by verifying symlinks
    needs_stow=false

    while IFS= read -r -d '' file; do
      # Get the relative path of the file within the package
      relative="${file#"$DOTFILES/$pkg/"}"
      target="$HOME/$relative"

      if [[ -L "$target" ]]; then
        # Symlink exists — check if it points to the right place
        link_target=$(readlink "$target")
        expected="$DOTFILES/$pkg/$relative"
        # Resolve the symlink to absolute path for comparison
        resolved=$(cd "$(dirname "$target")" && cd "$(dirname "$link_target")" && echo "$(pwd)/$(basename "$link_target")")
        if [[ "$resolved" != "$expected" ]]; then
          needs_stow=true
          break
        fi
      else
        needs_stow=true
        break
      fi
    done < <(find "$DOTFILES/$pkg" -type f -not -name '.DS_Store' -print0)

    if $needs_stow; then
      info "Stowing $pkg..."
      # Use --adopt to handle existing files, then restore repo versions
      stow -v -d "$DOTFILES" -t "$HOME" --adopt "$pkg" 2>&1 | sed 's/^/  /'
    else
      skip "$pkg already stowed correctly"
    fi
  done

  # After adopting, restore dotfiles repo versions over any adopted files
  if git -C "$DOTFILES" diff --quiet 2>/dev/null; then
    skip "No adopted files to restore"
  else
    info "Restoring repo versions of adopted files..."
    git -C "$DOTFILES" checkout -- .
  fi

  ok "Stow packages"

  # ~/.agents is a direct symlink to the dotfiles agents package (not stow-managed)
  # so CLI tools that install skills land directly in dotfiles without needing a restow
  if [[ "$(readlink "$HOME/.agents")" == "$DOTFILES/agents/.agents" ]]; then
    skip "~/.agents already symlinked to dotfiles"
  else
    if [[ -e "$HOME/.agents" ]] || [[ -L "$HOME/.agents" ]]; then
      warn "~/.agents exists but is not pointing to dotfiles — removing and relinking"
      rm -rf "$HOME/.agents"
    fi
    ln -s "$DOTFILES/agents/.agents" "$HOME/.agents"
    ok "~/.agents symlinked to dotfiles"
  fi
fi

# ── Sheldon plugins ────────────────────────────────────────────────
if should_run sheldon; then
  if command -v sheldon &>/dev/null; then
    info "Locking Sheldon plugins..."
    sheldon lock
    ok "Sheldon plugins"
  else
    warn "Sheldon not found — skipping plugin lock (run with --brew first)"
  fi
fi

# ── macOS defaults ──────────────────────────────────────────────────
if should_run macos; then
  if [[ "$OSTYPE" == darwin* ]]; then
    info "Applying macOS defaults..."
    bash "$DOTFILES/macos.sh"
    ok "macOS defaults"
  else
    skip "Not macOS — skipping"
  fi
fi

# ── Default shell ──────────────────────────────────────────────────
if should_run shell; then
  current_shell=$(dscl . -read "/Users/$(whoami)" UserShell | awk '{print $2}')
  if [[ "$current_shell" != "/bin/zsh" ]]; then
    info "Setting zsh as default shell..."
    sudo dscl . -change "/Users/$(whoami)" UserShell "$current_shell" /bin/zsh
    ok "Default shell set to zsh"
  else
    skip "Default shell already zsh"
  fi
fi

echo ""
ok "Done! Open a new terminal to use your setup."
